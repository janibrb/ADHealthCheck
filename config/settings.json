                   },
    "EntraID":  {
                    "SyncServer":  "SRVSYNC01",
                    "AutoUpdateVersion":  true,
                    "ExpectedAgentVersion":  "2.6.3.0",
                    "ServicesToCheck":  [
                                            "Microsoft Azure AD Connect Agent Updater",
                                            "Microsoft Azure AD Connect Authentication Agent",
                                            "Microsoft Azure AD Sync",
                                            "Microsoft Entra Connect Health Agent"
                                        ]
                },
    "Execution":  {
                      "ParallelThrottle":  10,
                      "LogLevel":  "Info"
                  },
    "DNS":  {
                "TargetServer":  "SRVDC01.ad.domain.local"
            },
    "ShowRecommendations":  {
                                "Sites":  true,
                                "Security":  true,
                                "DNS":  true,
                                "Backup":  true,
                                "DCDIag":  false,
                                "DCSystem":  true,
                                "Entra":  true,
                                "DomainOverview":  true,
                                "FSMO":  true,
                                "OUAccountSecurity":  true,
                                "Services":  true
                            }
}
