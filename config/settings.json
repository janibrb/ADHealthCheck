{
    "DefaultLanguage":  "de",
    "Company":  {
                    "Name":  "LAKE Solutions AG",
                    "Address":  "Hertistrasse 2, 8304 Wallisellen",
                    "LogoUrl":  "./templates/logo-lake-transparent.png"
                },
    "Paths":  {
                  "Output":  "./output/reports",
                  "Data":  "./output/data",
                  "Logs":  "./output/logs"
              },
